      "index": "b06",
      "roundness": null,
      "seed": 49956994,
      "version": 1184,
      "versionNonce": 1665947678,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783504547892,
      "link": null,
      "locked": false,
      "text": "รายได้จากไฟล์ดิจิทัล (Digital-Only Download):\nสำหรับลูกค้าที่ต้องการแค่ไฟล์ภาพคมชัดที่รีทัชแล้วไปอัปโหลดต่อในระบบออนไลน์\n(เช่น สมัครสอบ, ยื่นวีซ่าออนไลน์)",
      "fontSize": 14.329155050292451,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "รายได้จากไฟล์ดิจิทัล (Digital-Only Download): สำหรับลูกค้าที่ต้องการแค่ไฟล์ภาพคมชัดที่รีทัชแล้วไปอัปโหลดต่อในระบบออนไลน์ (เช่น สมัครสอบ, ยื่นวีซ่าออนไลน์)",
      "autoResize": false,
      "lineHeight": 1.25
    },
