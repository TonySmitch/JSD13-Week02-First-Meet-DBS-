      "isDeleted": false,
      "boundElements": [],
      "updated": 1783504547892,
      "link": null,
      "locked": false,
      "text": "รายได้จากการพิมพ์และจัดส่ง (Physical Print + Delivery):\nคิดราคาเหมาตามแพ็คเกจ (เช่น รูปติดบัตร 1 โหล + จัดส่งด่วน)",
      "fontSize": 14.329155050292451,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "รายได้จากการพิมพ์และจัดส่ง (Physical Print + Delivery): คิดราคาเหมาตามแพ็คเกจ (เช่น รูปติดบัตร 1 โหล + จัดส่งด่วน)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "fRbdkB2hy6Ubu3YVMegep",
      "type": "text",
      "x": 817.1533526489959,
      "y": 619.2623843880833,
      "width": 496.59338582143374,
      "height": 53.73433143859669,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
