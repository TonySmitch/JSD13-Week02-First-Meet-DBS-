    {
      "id": "OpYpFFrv5qteOtE3WVd5t",
      "type": "text",
      "x": 278.4728229108018,
      "y": 178.443991427508,
      "width": 205.67946219635786,
      "height": 236.0639886270453,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aL",
      "roundness": null,
      "seed": 786975464,
      "version": 465,
      "versionNonce": 1752629214,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783504547891,
      "link": null,
      "locked": false,
      "text": "กลุ่มฟรีแลนซ์/ช่างภาพดิจิทัล:\nสำหรับรับงานรีทัชภาพแบบ On-\ndemand\n\n- ขนส่งพัสดุ/ไรเดอร์ด่วน: เช่น\nFlash, J&T, Grab, Line Man\n\n- ร้านพิมพ์ภาพพาร์ทเนอร์: \nหากไม่ลงทุนเครื่องพิมพ์เองในระย\nะแรก\n\n- ซัพพลายเออร์:\nกระดาษและหมึกพิมพ์คุณภาพสูง",
      "fontSize": 14.527014684741252,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "กลุ่มฟรีแลนซ์/ช่างภาพดิจิทัล: สำหรับรับงานรีทัชภาพแบบ On-demand\n\n- ขนส่งพัสดุ/ไรเดอร์ด่วน: เช่น Flash, J&T, Grab, Line Man\n\n- ร้านพิมพ์ภาพพาร์ทเนอร์: \nหากไม่ลงทุนเครื่องพิมพ์เองในระยะแรก\n\n- ซัพพลายเออร์: กระดาษและหมึกพิมพ์คุณภาพสูง",
      "autoResize": false,
      "lineHeight": 1.25
    },
